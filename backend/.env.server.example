# Server deployment example. Replace all placeholder values before use.

APP_NAME=IDP PoC Workbench Backend
API_PREFIX=/api
IDP_EDITION=community
HOST=0.0.0.0
PORT=5006
RELOAD=false

RUNTIME_DATA_DIR=/opt/idp/backend/.runtime
# SAMPLE_DOC_DIR=/opt/idp/backend/.runtime/sample-doc
BACKEND_CORS_ORIGINS=https://example.com
BACKEND_PUBLIC_BASE_URL=https://api.example.com
BACKEND_DEBUG=false
LOG_LEVEL=info

AUTH_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_NAME=idp_poc_session
AUTH_SESSION_TTL_SECONDS=604800

# Community edition defaults to SQLite when DATABASE_URL is empty.
# DATABASE_URL=sqlite+pysqlite:////opt/idp/backend/.runtime/idp-community.db
# Non-SQLite DATABASE_URL is ignored in community mode unless this is explicitly enabled.
IDP_COMMUNITY_ALLOW_EXTERNAL_DATABASE=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DB_ECHO=false

MINERU_TOKEN=replace-with-your-mineru-token
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_MODEL_VERSION=vlm
MINERU_LANGUAGE=ch
MINERU_ENABLE_FORMULA=true
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_OCR=false

# auto: use OSS when valid OSS keys are configured, otherwise local runtime objects.
# local: always use backend/.runtime/objects.
# oss: require OSS credentials and fail fast when missing.
OBJECT_STORAGE_PROVIDER=auto
OSS_ACCESS_KEY_ID=replace-with-your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=replace-with-your-oss-access-key-secret
OSS_REGION=cn-beijing
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_BUCKET=replace-with-your-oss-bucket
OSS_PUBLIC_BASE_URL=https://replace-with-your-oss-bucket.oss-cn-beijing.aliyuncs.com

DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-27b
